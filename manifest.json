{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_popup": "src/popup/popup.html"
   },
   "background": {
      "service_worker": "src/background/background.js"
   },
   "content_scripts": [ {
      "js": [ "src/page/pageInject.js" ],
      "matches": [ "https://chat.openai.com/*", "https://chatgpt.com/*" ],
      "run_at": "document_start"
   }, {
      "js": [ "src/page/wasmLoader.js", "src/page/mainWorld.js" ],
      "matches": [ "https://chat.openai.com/*", "https://chatgpt.com/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "src/content/index.js" ],
      "matches": [ "https://chat.openai.com/*", "https://chatgpt.com/*" ],
      "run_at": "document_idle"
   } ],
   "description": "Stop browser freezing and lag in long ChatGPT conversations. Instantly speeds up the entire UI and reduces memory usage.",
   "host_permissions": [ "https://chat.openai.com/*", "https://chatgpt.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Speed Booster for ChatGPT – Fix Lag & Freezing in Long Chats[Crack]",
   "optional_host_permissions": [ "https://api.freemius.com/*" ],
   "permissions": [ "storage", "activeTab" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.1.5",
   "web_accessible_resources": [ {
      "matches": [ "https://chatgpt.com/*", "https://chat.openai.com/*" ],
      "resources": [ "src/wasm/build/trimmer.wasm", "src/page/wasmLoader.js" ]
   } ]
}
